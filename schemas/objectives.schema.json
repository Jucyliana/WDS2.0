{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Objectives Schema",
  "description": "Schema for objectives.json files containing objective markers and scenarios",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["Name", "Items"],
    "properties": {
      "Name": {
        "type": "string",
        "description": "Name of the objective scenario"
      },
      "Items": {
        "type": "array",
        "description": "Array of objective items (tokens, markers, etc.)",
        "items": {
          "type": "object",
          "required": ["Id", "Type", "PosX", "PosY"],
          "properties": {
            "Id": {
              "type": "string",
              "description": "ID of the objective item"
            },
            "Type": {
              "type": "string",
              "description": "Type of the objective item (e.g., Token)"
            },
            "PosX": {
              "type": "string",
              "description": "X coordinate position on the map"
            },
            "PosY": {
              "type": "string",
              "description": "Y coordinate position on the map"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
